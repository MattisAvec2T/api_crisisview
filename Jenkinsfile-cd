pipeline {
    agent { label 'docker-agent' }

    parameters {
        string(name: 'VM_IP',      defaultValue: '0.0.0.0', description: 'Adresse IP de la VM api')
        string(name: 'VM_USER',    defaultValue: 'ubuntu',  description: 'Utilisateur SSH')
        string(name: 'PORT',       defaultValue: '3001',    description: 'Port exposé sur l\'API')
        string(name: 'IMAGE_TAG',  defaultValue: 'latest',  description: 'Tag de l\'image à déployer — "latest" correspond à la version la plus récente, indiquer un numéro de build pour rollback (ex. 6)')
    }

    environment {
        IMAGE_NAME     = 'api-crisisview'
        CONTAINER_NAME = 'api-crisisview'
    }

    stages {

        stage('Deploy') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKERHUB_USER',
                    passwordVariable: 'DOCKERHUB_TOKEN'
                )]) {
                    sshagent(['vm-ssh-key-api']) {
                        sh "ssh -o StrictHostKeyChecking=no ${params.VM_USER}@${params.VM_IP} 'docker pull ${DOCKERHUB_USER}/${IMAGE_NAME}:${params.IMAGE_TAG}; docker rm -f ${CONTAINER_NAME} || true; docker run -d --name ${CONTAINER_NAME} -p ${params.PORT}:3001 ${DOCKERHUB_USER}/${IMAGE_NAME}:${params.IMAGE_TAG}'"
                    }
                }
            }
        }

    }

    post {
        success {
            echo "API déployée sur ${params.VM_IP}:${params.PORT} (tag: ${params.IMAGE_TAG})"
        }
        failure {
            echo 'Le déploiement a échoué — vérifier les logs ci-dessus.'
        }
    }
}
