pipeline {
    agent { label 'docker-agent' }

    parameters {
        string(name: 'VM_IP',     defaultValue: '0.0.0.0',    description: 'Adresse IP de la VM api')
        string(name: 'VM_USER',   defaultValue: 'ubuntu',     description: 'Utilisateur SSH')
        string(name: 'PORT',      defaultValue: '3001',        description: 'Port exposé sur l\'API')
        string(name: 'IMAGE_TAG', defaultValue: 'latest',      description: 'Tag de l\'image à déployer — "latest" correspond à la version la plus récente, indiquer un numéro de build pour rollback (ex. 6)')
        string(name: 'DB_NAME',   defaultValue: 'incident_db', description: 'Nom de la base de données')
    }

    environment {
        IMAGE_NAME = 'api-crisisview'
    }

    stages {

        stage('Deploy') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKERHUB_USER',  passwordVariable: 'DOCKERHUB_TOKEN'),
                    usernamePassword(credentialsId: 'db-credentials',         usernameVariable: 'DB_USER',         passwordVariable: 'DB_PASSWORD'),
                    string(credentialsId: 'db-root-password', variable: 'DB_ROOT_PASSWORD')
                ]) {
                    sshagent(['vm-ssh-key-api']) {
                        sh "printf 'DOCKERHUB_USER=${DOCKERHUB_USER}\\nIMAGE_TAG=${params.IMAGE_TAG}\\nPORT=${params.PORT}\\nDB_NAME=${params.DB_NAME}\\nDB_USER=${DB_USER}\\n' > .env.prod"
                        sh 'printf "DB_PASSWORD=$DB_PASSWORD\\nDB_ROOT_PASSWORD=$DB_ROOT_PASSWORD\\n" >> .env.prod'
                        sh "scp -o StrictHostKeyChecking=no compose.prod.yml ${params.VM_USER}@${params.VM_IP}:/home/${params.VM_USER}/compose.prod.yml"
                        sh "scp -o StrictHostKeyChecking=no .env.prod ${params.VM_USER}@${params.VM_IP}:/tmp/.env.api"
                        sh 'rm .env.prod'
                        sh "ssh -o StrictHostKeyChecking=no ${params.VM_USER}@${params.VM_IP} 'docker rm -f api-crisisview || true && docker compose -f /home/${params.VM_USER}/compose.prod.yml --env-file /tmp/.env.api pull && docker compose -f /home/${params.VM_USER}/compose.prod.yml --env-file /tmp/.env.api up -d && rm /tmp/.env.api'"
                    }
                }
            }
        }

    }

    post {
        success {
            echo "API déployée sur ${params.VM_IP}:${params.PORT} (tag: ${params.IMAGE_TAG})"
        }
        failure {
            echo 'Le déploiement a échoué — vérifier les logs ci-dessus.'
        }
    }
}
